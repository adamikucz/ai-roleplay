{
  "name": "aether-roleplay-platform",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "db:up": "docker compose up -d postgres redis",
    "db:schema": "psql $DATABASE_URL -f infra/postgres/schema.sql",
    "dev:api": "pnpm --filter @aether/api dev",
    "dev:web": "pnpm --filter @aether/web dev"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.4",
    "typescript": "^5.7.2"
  }
}
